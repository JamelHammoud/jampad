{
  "name": "@jamelhammoud/jampad",
  "version": "0.1.4",
  "description": "A Notion-style, local-first wiki & chat that boots from a single config file.",
  "license": "MIT",
  "author": "Jamel Hammoud",
  "repository": "github:JamelHammoud/jampad",
  "homepage": "https://github.com/JamelHammoud/jampad",
  "type": "module",
  "bin": {
    "jampad": "./bin/jampad.mjs"
  },
  "exports": {
    "./config": {
      "types": "./src/server/lib/config.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "bun run src/cli.ts dev",
    "build:client": "vite build",
    "build:server": "bun build src/cli.ts --target=node --outfile=dist/cli.js --external=jiti --external=vite --external=@vitejs/plugin-react --external=@tailwindcss/vite --external=@tailwindcss/postcss --minify",
    "build": "bun run build:client && bun run build:server",
    "build:binary": "bun run build:client && bun scripts/embed-assets.ts && bun build --compile --outfile=jampad ./src/cli.ts && bun scripts/reset-assets.ts",
    "start": "bun run src/cli.ts start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "bun run build && vitest run --config vitest.integration.config.ts",
    "prepublishOnly": "bun run typecheck && bun run lint && bun run test && bun run test:integration"
  },
  "files": [
    "bin",
    "src",
    "dist",
    "vite.config.ts",
    "tsconfig.json",
    "jampad.config.example.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "notion",
    "wiki",
    "editor",
    "blocknote",
    "markdown",
    "local-first"
  ],
  "dependencies": {},
  "devDependencies": {
    "@blocknote/core": "0.48.1",
    "@blocknote/mantine": "0.48.1",
    "@blocknote/react": "0.48.1",
    "@emoji-mart/data": "^1.2.1",
    "@excalidraw/excalidraw": "^0.18.1",
    "@emoji-mart/react": "^1.1.1",
    "@eslint/js": "^10.0.1",
    "@floating-ui/dom": "^1.6.0",
    "@hono/node-server": "^1.13.7",
    "@mantine/core": "^8.3.11",
    "@mantine/hooks": "^8.3.11",
    "@mantine/utils": "^6.0.22",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.5",
    "clsx": "^2.1.1",
    "emoji-mart": "^5.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fuse.js": "^7.0.0",
    "globals": "^17.5.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.6.13",
    "lucide-react": "^0.469.0",
    "prettier": "^3.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.0.5",
    "vitest": "^4.1.5",
    "zod": "^4.3.6"
  }
}
