{
  "name": "@jamelhammoud/jampad",
  "version": "0.1.0-alpha.1",
  "description": "A Notion-style, local-first wiki & chat that boots from a single config file.",
  "license": "MIT",
  "author": "Jamel Hammoud",
  "repository": "github:JamelHammoud/jampad",
  "homepage": "https://github.com/JamelHammoud/jampad",
  "bin": {
    "jampad": "./bin/jampad.mjs"
  },
  "exports": {
    "./config": "./src/lib/config.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "files": [
    "bin",
    "src",
    "next.config.mjs",
    "postcss.config.mjs",
    "tsconfig.json",
    "next-env.d.ts",
    "jampad.config.example.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "notion",
    "wiki",
    "editor",
    "blocknote",
    "nextjs",
    "markdown",
    "local-first"
  ],
  "dependencies": {
    "@blocknote/core": "0.48.1",
    "@blocknote/mantine": "0.48.1",
    "@blocknote/react": "0.48.1",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@floating-ui/dom": "^1.6.0",
    "@mantine/core": "^8.3.11",
    "@mantine/hooks": "^8.3.11",
    "@mantine/utils": "^6.0.22",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/postcss": "^4.0.0",
    "clsx": "^2.1.1",
    "emoji-mart": "^5.6.0",
    "fuse.js": "^7.0.0",
    "gray-matter": "^4.0.3",
    "jiti": "^2.4.2",
    "lucide-react": "^0.469.0",
    "next": "^15.5.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
